# 3 # Estimating read counts and TPM using HTSeqcount and Stringtie2, respectively. 
#!/bin/bash
# We estimated read counts for genes using HTSeq-count with --minaqual 10 to remove reads with 10% probability of multiple alignments, 
# We calculated transcript--per--million (TPM) of each gene using Stringtie2.

# Paths
ANNO_HTSEQ="/shares_bgfs/margres_lab/Snakes/Genomes/Cadam/DRR0105/MASTER_Cadam_annos_used_for_qMS-REF_18Aug23.gff3"
ANNO_STRINGTIE="/shares_bgfs/margres_lab/Snakes/Genomes/Cadam/DRR0105/MASTER_Cadam_genes_cds_mRNA_30Jun21.gff3"
BAM_DIR="/shares_bgfs/margres_lab/Snakes/Transcriptomes/Cadam/Analyses/hisat2"
ST2_DIR="/shares_bgfs/margres_lab/Snakes/Transcriptomes/Cadam/Analyses/stringtie2"

mkdir -p $ST2_DIR

for BAM in ${BAM_DIR}/*_VG_Sorted.bam; do
    SAMPLE=$(basename "$BAM" _VG_Sorted.bam)
    
    # --- HTSeq-count ---
    htseq-count \
        --nprocesses=5 \
        --format=bam --type=gene --idattr=ID \
        --stranded=no --order=pos --nonunique=all -a=10 \
        --counts_output=${BAM_DIR}/${SAMPLE}_VenomGland.csv \
        $BAM $ANNO_HTSEQ

    # --- StringTie ---
    stringtie -p 50 -G $ANNO_STRINGTIE -e \
        -o ${ST2_DIR}/${SAMPLE}_VenomGland.gtf \
        -B -A ${ST2_DIR}/${SAMPLE}_VenomGland_abund.tab \
        $BAM

    echo "Finished processing $SAMPLE"
done

