# 1 # Trimming raw reads
#!/bin/bash
# We trimmed all reads using Trim Galore! with default parameters (fastqc)

RAW_DIR="/shares_bgfs/margres_lab/Snakes/Transcriptomes/Cadam/raw"
OUT_DIR="/shares_bgfs/margres_lab/Snakes/Transcriptomes/Cadam/trimmed_reads"

mkdir -p $OUT_DIR

# Loop through R1 files and find matching R2
for R1 in ${RAW_DIR}/*_R1_001.fastq.gz; do
    R2=${R1/_R1_001.fastq.gz/_R2_001.fastq.gz}
    
    trim_galore --paired --fastqc --gzip \
        -o $OUT_DIR \
        $R1 $R2
done

